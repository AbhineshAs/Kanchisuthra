<footer class="footer" id="SiteFooter">
  <div class="footer__inner container">
    <div class="footer__columns">
      <!-- Brand Column -->
      <div class="footer__col footer__col--brand">
        {% if settings.logo != blank %}
          {{ settings.logo | image_url: width: 150 | image_tag: class: 'footer__logo', alt: shop.name }}
        {% else %}
          <span class="footer__brand-name">{{ shop.name }}</span>
        {% endif %}
        <p class="footer__tagline">Timeless Handloom. Modern Elegance.</p>
        {% if section.settings.show_social_links %}
          <div class="footer__social">
            {% if settings.instagram_url != blank %}
              <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {% endif %}
            {% if settings.facebook_url != blank %}
              <a href="{{ settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook" class="footer__social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {% endif %}
            {% if settings.pinterest_url != blank %}
              <a href="{{ settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest" class="footer__social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83l1.24-5.26s-.32-.63-.32-1.57c0-1.47.85-2.57 1.91-2.57.9 0 1.34.68 1.34 1.49 0 .91-.58 2.27-.88 3.53-.25 1.05.52 1.91 1.55 1.91 1.86 0 3.11-2.37 3.11-5.17 0-2.13-1.44-3.62-3.49-3.62-2.38 0-3.77 1.79-3.77 3.64 0 .72.28 1.49.62 1.91.07.08.08.15.06.23l-.23.95c-.04.14-.12.17-.28.1-1.04-.48-1.69-2-1.69-3.22 0-2.62 1.9-5.02 5.48-5.02 2.88 0 5.12 2.05 5.12 4.79 0 2.86-1.8 5.16-4.3 5.16-.84 0-1.63-.44-1.9-.95l-.52 1.93c-.19.72-.69 1.62-1.03 2.17.78.24 1.6.37 2.45.37 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
              </a>
            {% endif %}
            {% if settings.whatsapp_url != blank %}
              <a href="{{ settings.whatsapp_url }}" target="_blank" rel="noopener" aria-label="WhatsApp" class="footer__social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Quick Links -->
      <div class="footer__col">
        <h4 class="footer__heading">Quick Links</h4>
        <ul class="footer__links" role="list">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="{{ routes.collections_url }}">Collections</a></li>
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/blogs/news">Blog</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
        </ul>
      </div>

      <!-- Customer Service -->
      <div class="footer__col">
        <h4 class="footer__heading">Customer Service</h4>
        <ul class="footer__links" role="list">
          <li><a href="{{ routes.account_url }}">My Account</a></li>
          <li><a href="{{ routes.account_url }}orders">Order History</a></li>
          <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
          <li><a href="/pages/return-policy">Return & Exchange</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      {% if section.settings.show_newsletter %}
        <div class="footer__col footer__col--newsletter">
          <h4 class="footer__heading">{{ section.settings.newsletter_heading | default: 'Join Our World' }}</h4>
          <p class="footer__newsletter-text">{{ section.settings.newsletter_subtext | default: 'Subscribe for exclusive offers and new arrivals.' }}</p>
          {% form 'customer' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="footer__newsletter-form">
              <input type="email" name="contact[email]" placeholder="Your email address" class="footer__newsletter-input" required>
              <button type="submit" class="btn footer__newsletter-btn">Subscribe</button>
            </div>
            {% if form.posted_successfully? %}
              <p class="footer__newsletter-success">Thank you for subscribing!</p>
            {% endif %}
          {% endform %}
        </div>
      {% endif %}
    </div>

    <!-- Footer Bottom -->
    <div class="footer__bottom">
      <p class="footer__copyright">{{ section.settings.copyright_text | default: '© 2025 Kanchisuthra. All Rights Reserved.' }}</p>
      <div class="footer__policy-links">
        <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
        <a href="{{ shop.terms_of_service.url }}">Terms of Service</a>
        <a href="{{ shop.refund_policy.url }}">Refund Policy</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_social_links",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter Signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Join Our World"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter Subtext",
      "default": "Subscribe for exclusive offers and new arrivals."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© 2025 Kanchisuthra. All Rights Reserved."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
