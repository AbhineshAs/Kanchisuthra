<header class="header{% if section.settings.sticky_header_type == 'on-scroll-up' %} header--sticky{% endif %}" id="SiteHeader">
  <div class="header__inner container">
    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        {% assign logo_alt = section.settings.logo.alt | default: shop.name %}
        {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag: class: 'header__logo-image', alt: logo_alt, loading: 'eager' }}
      {% else %}
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <!-- Navigation -->
    <nav class="header__nav" aria-label="Main navigation">
      {% if section.settings.menu != blank %}
        <ul class="header__nav-list" role="list">
          {% for link in linklists[section.settings.menu].links %}
            <li class="header__nav-item{% if link.links.size > 0 %} header__nav-item--has-dropdown{% endif %}">
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}">
                {{ link.title }}
                {% if link.links.size > 0 %}
                  <span class="header__nav-arrow" aria-hidden="true">&#9660;</span>
                {% endif %}
              </a>
              {% if link.links.size > 0 %}
                <ul class="header__dropdown" role="list">
                  {% for sub_link in link.links %}
                    <li class="header__dropdown-item">
                      <a href="{{ sub_link.url }}" class="header__dropdown-link">{{ sub_link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    <!-- Icons -->
    <div class="header__icons">
      {% if section.settings.show_search_icon %}
        <button class="header__icon-btn" id="SearchToggle" aria-label="Search" data-search-toggle>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      {% endif %}

      {% if section.settings.show_wishlist_icon %}
        <a href="/pages/wishlist" class="header__icon-btn" aria-label="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.show_cart_icon %}
        <a href="{{ routes.cart_url }}" class="header__icon-btn" aria-label="Cart" id="CartToggle" data-cart-toggle>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="header__cart-count" id="CartCount">{{ cart.item_count }}</span>
        </a>
      {% endif %}

      <!-- Mobile Hamburger -->
      <button class="header__hamburger" id="MobileMenuToggle" aria-label="Open menu" aria-expanded="false" aria-controls="MobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="header__mobile-menu" id="MobileMenu" aria-hidden="true">
    {% if section.settings.menu != blank %}
      <ul class="header__mobile-nav" role="list">
        {% for link in linklists[section.settings.menu].links %}
          <li><a href="{{ link.url }}" class="header__mobile-link">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 180
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "label": "Sticky Header",
      "options": [
        {"value": "none", "label": "None"},
        {"value": "on-scroll-up", "label": "On Scroll Up"}
      ],
      "default": "on-scroll-up"
    },
    {
      "type": "checkbox",
      "id": "show_search_icon",
      "label": "Show Search Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist_icon",
      "label": "Show Wishlist Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart_icon",
      "label": "Show Cart Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "label": "Show Bottom Border",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
